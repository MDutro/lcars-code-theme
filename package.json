{
  "name": "lcars-code-theme",
  "displayName": "LCARS",
  "description": "Star Trek LCARS color themes for VS Code, in three screen-accurate variants: TNG, DS9, and the film era.",
  "version": "0.1.1",
  "publisher": "MDutro",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "lcars",
    "star trek",
    "startrek",
    "color theme",
    "dark theme"
  ],
  "galleryBanner": {
    "color": "#0d0b08",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MDutro/lcars-code-theme"
  },
  "bugs": {
    "url": "https://github.com/MDutro/lcars-code-theme/issues"
  },
  "homepage": "https://github.com/MDutro/lcars-code-theme#readme",
  "contributes": {
    "themes": [
      {
        "label": "LCARS (TNG)",
        "uiTheme": "vs-dark",
        "path": "./themes/lcars-tng-color-theme.json"
      },
      {
        "label": "LCARS (DS9)",
        "uiTheme": "vs-dark",
        "path": "./themes/lcars-ds9-color-theme.json"
      },
      {
        "label": "LCARS (UDC)",
        "uiTheme": "vs-dark",
        "path": "./themes/lcars-udc-color-theme.json"
      }
    ]
  },
  "scripts": {
    "build": "node scripts/build-themes.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
