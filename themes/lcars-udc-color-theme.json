  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#2c6070"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#30c0d8"
      }
    },
    {
      "name": "String escape / regex",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#38b8c8"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#50d890"
      }
    },
    {
      "name": "Constant / boolean / language",
      "scope": [
        "constant.language",
        "constant.other",
        "variable.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#50d890"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#40e060"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#78c0d8"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#78c0d8"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#78c0d8"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#4888c0"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#30c8e0"
      }
    },
    {
      "name": "Type / class / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#3888d8"
      }
    },
    {
      "name": "Decorator / attribute / macro",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "entity.other.attribute-name",
        "punctuation.decorator",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#38b8c8"
      }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#408090"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#40e060"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx"
      ],
      "settings": {
        "foreground": "#30c8e0"
      }
    },
    {
      "name": "Invalid / error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#d83838"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#40e060"
      }
    },
    {
      "name": "Markup bold / strong",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#a8d8e8"
      }
    },
    {
      "name": "Markup italic / emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#78c0d8"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#30c8e0"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#408090"
      }
    },
    {
      "name": "Markup raw / code",
      "scope": [
        "markup.raw",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#30c0d8"
      }
    },
    {
      "name": "Markup inserted / deleted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#30c0d8"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#d83838"
      }
    },
    {
      "name": "Diff",
      "scope": [
        "meta.diff.header",
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#2c6070"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#408090"
    },
    "class": {
      "foreground": "#3888d8"
    },
    "enum": {
      "foreground": "#3888d8"
    },
    "enumMember": {
      "foreground": "#50d890"
    },
    "interface": {
      "foreground": "#3888d8"
    },
    "struct": {
      "foreground": "#3888d8"
    },
    "typeParameter": {
      "foreground": "#3888d8"
    },
    "type": {
      "foreground": "#3888d8"
    },
    "parameter": {
      "foreground": "#78c0d8"
    },
    "variable": {
      "foreground": "#78c0d8"
    },
    "property": {
      "foreground": "#4888c0"
    },
    "function": {
      "foreground": "#30c8e0"
    },
    "method": {
      "foreground": "#30c8e0"
    },
    "macro": {
      "foreground": "#38b8c8"
    },
    "decorator": {
      "foreground": "#38b8c8"
    },
    "variable.readonly": {
      "foreground": "#50d890"
    },
    "variable.defaultLibrary": {
      "foreground": "#40e060"
    },
    "property.readonly": {
      "foreground": "#50d890"
    },
    "deprecated": {
      "strikethrough": true
    }
  }
}
