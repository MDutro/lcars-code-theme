    },
    "struct": {
      "foreground": "#b06573"
    },
    "typeParameter": {
      "foreground": "#b06573"
    },
    "type": {
      "foreground": "#b06573"
    },
    "parameter": {
      "foreground": "#acc2be"
    },
    "variable": {
      "foreground": "#acc2be"
    },
    "property": {
      "foreground": "#88aaa4"
    },
    "function": {
      "foreground": "#40a8c8"
    },
    "method": {
      "foreground": "#40a8c8"
    },
    "macro": {
      "foreground": "#b87888"
    },
    "decorator": {
      "foreground": "#b87888"
    },
    "variable.readonly": {
      "foreground": "#48c8c0"
    },
    "variable.defaultLibrary": {
      "foreground": "#3cc8b8"
    },
    "property.readonly": {
      "foreground": "#48c8c0"
    },
    "deprecated": {
      "strikethrough": true
    }
  }
}
