  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#486860"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#50b8a0"
      }
    },
    {
      "name": "String escape / regex",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#b87888"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#48c8c0"
      }
    },
    {
      "name": "Constant / boolean / language",
      "scope": [
        "constant.language",
        "constant.other",
        "variable.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#48c8c0"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#3cc8b8"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#88aaa4"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#88aaa4"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#acc2be"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#88aaa4"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#40a8c8"
      }
    },
    {
      "name": "Type / class / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#b06573"
      }
    },
    {
      "name": "Decorator / attribute / macro",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "entity.other.attribute-name",
        "punctuation.decorator",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#b87888"
      }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#688880"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#3cc8b8"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx"
      ],
      "settings": {
        "foreground": "#40a8c8"
      }
    },
    {
      "name": "Invalid / error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#b06573"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#3cc8b8"
      }
    },
    {
      "name": "Markup bold / strong",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b3c1bd"
      }
    },
    {
      "name": "Markup italic / emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#acc2be"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#40a8c8"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#688880"
      }
    },
    {
      "name": "Markup raw / code",
      "scope": [
        "markup.raw",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#50b8a0"
      }
    },
    {
      "name": "Markup inserted / deleted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#3cc8b8"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#b06573"
      }
    },
    {
      "name": "Diff",
      "scope": [
        "meta.diff.header",
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#5b8479"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#688880"
