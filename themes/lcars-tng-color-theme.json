  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#61594c"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#d0a030"
      }
    },
    {
      "name": "String escape / regex",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#a098c8"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#d8b040"
      }
    },
    {
      "name": "Constant / boolean / language",
      "scope": [
        "constant.language",
        "constant.other",
        "variable.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#d8b040"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#c8a828"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#a89e90"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#a89e90"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c4ae80"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#a09268"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#7098c8"
      }
    },
    {
      "name": "Type / class / interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#8888c0"
      }
    },
    {
      "name": "Decorator / attribute / macro",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "entity.other.attribute-name",
        "punctuation.decorator",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#a098c8"
      }
    },
    {
      "name": "Namespace / module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#8c806e"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#c8a828"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx"
      ],
      "settings": {
        "foreground": "#7098c8"
      }
    },
    {
      "name": "Invalid / error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#cb5353"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#c8a828"
      }
    },
    {
      "name": "Markup bold / strong",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#cabca1"
      }
    },
    {
      "name": "Markup italic / emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#c2baad"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#7098c8"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#8c806e"
      }
    },
    {
      "name": "Markup raw / code",
      "scope": [
        "markup.raw",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#d0a030"
      }
    },
    {
      "name": "Markup inserted / deleted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#7098c8"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#cb5353"
      }
    },
    {
      "name": "Diff",
      "scope": [
        "meta.diff.header",
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#61594c"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#8c806e"
    },
    "class": {
      "foreground": "#8888c0"
    },
    "enum": {
      "foreground": "#8888c0"
    },
    "enumMember": {
      "foreground": "#d8b040"
    },
    "interface": {
      "foreground": "#8888c0"
    },
    "struct": {
      "foreground": "#8888c0"
    },
    "typeParameter": {
      "foreground": "#8888c0"
    },
    "type": {
      "foreground": "#8888c0"
    },
    "parameter": {
      "foreground": "#c4ae80"
    },
    "variable": {
      "foreground": "#c4ae80"
    },
    "property": {
      "foreground": "#a09268"
    },
    "function": {
      "foreground": "#7098c8"
    },
    "method": {
      "foreground": "#7098c8"
    },
    "macro": {
      "foreground": "#a098c8"
    },
    "decorator": {
      "foreground": "#a098c8"
    },
    "variable.readonly": {
      "foreground": "#d8b040"
    },
    "variable.defaultLibrary": {
      "foreground": "#c8a828"
    },
    "property.readonly": {
      "foreground": "#d8b040"
    },
    "deprecated": {
      "strikethrough": true
    }
  }
}
